<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Department Bean -->
    <bean id="department" class="com.capgemini.spring_assignment_1.Department">
        <property name="departmentId" value="10"/>
        <property name="departmentName" value="IT"/>
    </bean>

    <!-- Employee Bean -->
    <bean id="employee" class="com.capgemini.spring_assignment_1.Employee">
        <property name="employeeId" value="101"/>
        <property name="employeeName" value="John"/>
        <property name="salary" value="50000"/>
        <property name="department" ref="department"/>
    </bean>

</beans>