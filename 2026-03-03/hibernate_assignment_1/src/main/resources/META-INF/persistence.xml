<?xml version="1.0" encoding="UTF-8"?>
	
<persistence xmlns="http://java.sun.com/xml/ns/persistence"
	         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	         xsi:schemaLocation="http://java.sun.com/xml/ns/persistence
	http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
	             version="2.0">
		
	<persistence-unit name="PU01">

		<provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
	
		<class>com.capgemini.hibernate_assignment_1.entity.Employee</class>
		<class>com.capgemini.hibernate_assignment_1.entity.SalaryRecord</class>
		<class>com.capgemini.hibernate_assignment_1.entity.PerformanceReview</class>
	
		<properties>
	
			<property name="javax.persistence.jdbc.driver"
	        		  value="org.postgresql.Driver"/>
	
			<property name="javax.persistence.jdbc.url"
			          value="jdbc:postgresql://localhost:5432/assignmentdb"/>
			
			<property name="javax.persistence.jdbc.user"
			          value="postgres"/>
			
			<property name="javax.persistence.jdbc.password"
			          value="Sudutta#2026"/>
			
			<property name="hibernate.hbm2ddl.auto"
			          value="update"/>
			
			<property name="hibernate.show_sql"
			          value="true"/>
			
			<property name="hibernate.format_sql"
			          value="true"/>
			
			<property name="hibernate.dialect"
			          value="org.hibernate.dialect.PostgreSQLDialect"/>
	
		</properties>
		
	</persistence-unit>
	 
</persistence>